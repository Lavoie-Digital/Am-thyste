rules_version = '2';

// Améthyste — Firestore security rules (defense in depth).
// The app reads/writes via the Admin SDK server-side (which bypasses these
// rules); these lock down any direct client-SDK access.
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }
    function isAdmin() {
      return isSignedIn() && request.auth.token.role == 'admin';
    }

    // Products: public read (the server still strips reseller prices for SSR);
    // writes are admin-only.
    match /products/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Users: a user reads/creates their own doc; only admins change roles/status.
    match /users/{uid} {
      allow read: if isSignedIn() && (request.auth.uid == uid || isAdmin());
      allow create: if isSignedIn() && request.auth.uid == uid;
      allow update: if isAdmin()
        || (request.auth.uid == uid
            && !request.resource.data.diff(resource.data).affectedKeys()
                 .hasAny(['role', 'proStatus', 'approvedAt', 'approvedBy']));
      allow delete: if isAdmin();
    }

    // Orders: readable by their owner or an admin; only the server writes them.
    match /orders/{id} {
      allow read: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
      allow write: if false;
    }

    // Settings: public read, admin write.
    match /settings/{doc} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
